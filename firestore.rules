rules_version = '2';

// MuscleUp Firestore セキュリティルール
// Firebase Console → Firestore Database → ルール に貼り付けてください。
service cloud.firestore {
  match /databases/{database}/documents {

    // 個人データ: 本人のみ読み書き可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{sub=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 種目マスタ: 認証済みユーザーは読み取り可、書き込み不可（管理者のみ）
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ジムチェックイン（共有）: 認証済みは全件読み取り可。
    // 作成は本人のUIDでのみ。削除・更新は投稿者本人のみ。
    match /checkins/{checkinId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // 種目アドバイス（共有）: 認証済みは読み取り可。
    // 作成は本人のUIDで。削除は本人のみ。
    // 更新は likeCount の増減のみ許可（いいね機能）。
    match /exerciseAdvice/{adviceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount']);
    }
  }
}
